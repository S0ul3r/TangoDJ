# TangoDJ — Spotify + Supabase credentials
# 1. Create a Spotify app at https://developer.spotify.com/dashboard
# 2. Add Redirect URIs (both if you use local + Vercel):
#      http://127.0.0.1:3000/callback
#      https://YOUR-APP.vercel.app/callback
#    (Spotify may block "localhost" — use 127.0.0.1 locally)
# 3. Create a Supabase project and run supabase/schema.sql
# 4. Copy this file to .env.local and fill in values
# 5. On Vercel → Project → Settings → Environment Variables, set at least
#    NEXT_PUBLIC_SPOTIFY_CLIENT_ID (and Supabase keys). Redirect URI is taken
#    from the browser origin at login time; keep REDIRECT_URI in sync for docs.

NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_client_id
# Used as fallback; live login uses window.location.origin + /callback
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
